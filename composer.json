{
    "name": "glue-agency/craft-influx",
    "description": "Connects Craft elements to external JSON APIs. Links are stored in Project Config.",
    "type": "craft-plugin",
    "license": "mit",
    "require": {
        "php": ">=8.1",
        "craftcms/cms": "^4.0|^5.0",
        "cakephp/utility": "^3.3.12|^4.0|^5.0"
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "^3.0",
        "craftcms/ecs": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "GlueAgency\\Influx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GlueAgency\\Influx\\Tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "influx",
        "name": "Influx",
        "developer": "Glue Agency",
        "documentationUrl": "https://github.com/glue-agency/craft-influx/blob/master/README.md",
        "class": "GlueAgency\\Influx\\Influx"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "scripts": {
        "test": "codecept run unit",
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi"
    }
}
