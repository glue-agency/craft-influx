{
    "name": "tdm/craft-influx",
    "description": "YAML-configured remote JSON feeds for Craft CMS. Hydrates existing element types (Entries, Calendar Events, etc.) from remote APIs.",
    "type": "craft-plugin",
    "license": "mit",
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.0",
        "cakephp/utility": "^5.0",
        "symfony/yaml": "^6.0||^7.0"
    },
    "autoload": {
        "psr-4": {
            "TDM\\Influx\\": "src/"
        }
    },
    "extra": {
        "handle": "influx",
        "name": "Influx",
        "developer": "Thomas De Marez",
        "documentationUrl": "",
        "class": "TDM\\Influx\\Influx"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
