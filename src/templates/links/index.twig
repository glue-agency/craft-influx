{% extends "_layouts/cp" %}

{% import "_includes/forms" as forms %}
{% import "influx/_overview" as ui %}

{% set title = "Links"|t("influx") %}
{% set selectedSubnavItem = "links" %}

{# Canonical order for the processing pills (write actions first, then the
   reconciliation actions), so they always read the same regardless of the
   order they were configured in. #}
{% set processingOrder = ["create", "update", "disable", "disable-for-site", "delete", "delete-for-site"] %}

{% block actionButton %}
    {% if readOnly %}
        <span class="light" style="display: inline-flex; align-items: center; gap: 6px;">
            <span data-icon="lock" aria-hidden="true"></span>{{ "Read-only"|t("influx") }}
        </span>
    {% else %}
        <a href="{{ cpUrl('influx/links/new') }}" class="btn submit add icon">
            {{ "New link"|t("influx") }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {% css %}
    /* Drag-to-sort handles on the links table. */
    .influx-links-table .move.icon { cursor: grab; }
    .influx-links-table tr.influx-dragging { opacity: 0.4; }

    /* The Sync-options menu otherwise inherits Craft's classic menu hover — a
       medium-grey fill (--gray-500) with white text — which reads heavy next
       to the rest of the UI. Override it (with enough specificity to beat
       Craft's own rule) with the lighter hover the plugin's other menus use. */
    .menu.influx-sync-menu:not(.menu--disclosure) ul li .menu-option:not(.sel, .disabled):hover {
        background-color: var(--gray-100);
        color: var(--text-color);
    }
    {% endcss %}

    {# Craft only applies a :hover background to anchor menu options; our sync
       presets are <button class="menu-option"> elements, which rely on a JS-
       added `.hover` class that doesn't fire here — so they sit dead on hover.
       Replicate Craft's own plain-menu hover look for them. The custom class
       survives Garnish teleporting `.menu` to <body> on open, keeping this
       scoped to the sync dropdown rather than every menu on the page. #}
    {% css %}
    .influx-sync-menu ul li .menu-option:not(.sel, .disabled) {
        transition: background-color 0.1s ease, color 0.1s ease;
    }
    .influx-sync-menu ul li .menu-option:not(.sel, .disabled):hover {
        color: var(--white) !important;
        --light-text-color: hsla(0, 0%, 100%, 0.8);
        background-color: var(--bg-selection-dark);
    }
    {% endcss %}

    {% if not readOnly %}
        {% js %}
        document.querySelectorAll('[data-influx-delete-form]').forEach(function (anchor) {
            anchor.addEventListener('click', function () {
                if (window.confirm({{ "Are you sure you want to delete this link? Its sync configuration is removed permanently — imported elements stay."|t("influx")|json_encode|raw }})) {
                    document.getElementById(anchor.dataset.influxDeleteForm).submit();
                }
            });
        });
        {% endjs %}

        {# Drag-to-sort the links table by the leading `.move` handle. Reorders
           the rows live during the drag (native HTML5 DnD, same mechanics as
           the builder's SiteEndpointsTable), then POSTs the new UID order to
           influx/links/reorder, which writes it back to Project Config. #}
        {% js %}
        (function () {
            const tbody = document.querySelector('[data-influx-links-sortable]');
            if (!tbody) {
                return;
            }

            let dragRow = null;
            let orderAtDragStart = null;

            const currentOrder = function () {
                return Array.from(tbody.children)
                    .map(function (tr) { return tr.dataset.uid; })
                    .filter(Boolean);
            };

            const persistOrder = function () {
                Craft.sendActionRequest('POST', 'influx/links/reorder', { data: { uids: currentOrder() } })
                    .then(function (response) {
                        Craft.cp.displayNotice((response.data && response.data.message) || Craft.t('influx', 'Link order saved.'));
                    })
                    .catch(function (e) {
                        const message = e.response && e.response.data && e.response.data.message;
                        Craft.cp.displayError(message || Craft.t('influx', 'Couldn’t save link order.'));
                    });
            };

            tbody.querySelectorAll('a.move').forEach(function (handle) {
                const row = handle.closest('tr');
                handle.setAttribute('draggable', 'true');

                handle.addEventListener('dragstart', function (e) {
                    dragRow = row;
                    orderAtDragStart = currentOrder().join(',');
                    e.dataTransfer.effectAllowed = 'move';
                    e.dataTransfer.setData('text/plain', row.dataset.uid || '');
                    e.dataTransfer.setDragImage(row, 0, 0);
                    row.classList.add('influx-dragging');
                });

                handle.addEventListener('dragend', function () {
                    row.classList.remove('influx-dragging');
                    const moved = dragRow;
                    dragRow = null;
                    if (moved && currentOrder().join(',') !== orderAtDragStart) {
                        persistOrder();
                    }
                });
            });

            tbody.addEventListener('dragover', function (e) {
                if (!dragRow) {
                    return;
                }
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                const over = e.target.closest('tr');
                if (!over || over === dragRow || over.parentNode !== tbody) {
                    return;
                }
                const rect = over.getBoundingClientRect();
                const after = (e.clientY - rect.top) > rect.height / 2;
                tbody.insertBefore(dragRow, after ? over.nextSibling : over);
            });
        })();
        {% endjs %}
    {% endif %}

    {% if readOnly %}
        <blockquote class="note">
            {{ "Administrative changes are disallowed in this environment. Link configuration is shown read-only — syncs can still be triggered."|t("influx") }}
        </blockquote>
    {% endif %}

    {% if links is empty %}
        <div class="zilch">
            <p>{{ "No links yet."|t("influx") }}</p>
            {% if readOnly %}
                <p class="light">{{ "Administrative changes are disallowed in this environment."|t("influx") }}</p>
            {% endif %}
        </div>
    {% else %}
        <table class="data fullwidth influx-links-table">
            <thead>
                <tr>
                    {% if not readOnly %}<th class="thin"></th>{% endif %}
                    <th>{{ "Link"|t("influx") }}</th>
                    <th>{{ "Sites"|t("influx") }}</th>
                    <th>{{ "Processing"|t("influx") }}</th>
                    <th>{{ "Last run"|t("influx") }}</th>
                    <th class="thin">{{ "Actions"|t("influx") }}</th>
                </tr>
            </thead>
            <tbody{% if not readOnly %} data-influx-links-sortable{% endif %}>
                {% for link in links %}
                    <tr data-id="{{ link.id }}" data-uid="{{ link.uid }}">
                        {% if not readOnly %}
                            <td class="thin action">
                                <a class="move icon" title="{{ 'Reorder'|t('influx') }}" role="button"></a>
                            </td>
                        {% endif %}

                        {# Identity: name on top, handle + target folded into one
                           muted meta line (was three separate columns). #}
                        <td>
                            <a href="{{ cpUrl('influx/links/' ~ link.id) }}"><strong>{{ link.name }}</strong></a>
                            <div class="influx-cell-meta">
                                <code>{{ link.handle }}</code>
                                <span aria-hidden="true">&middot;</span>
                                <span class="influx-cell-truncate">
                                    {{- presenter.elementTypeLabel(link) -}}
                                    {%- set criteria = presenter.targetCriteriaLabel(link) -%}
                                    {%- if criteria %} / {{ criteria }}{% endif -%}
                                </span>
                            </div>
                        </td>

                        {# Sites — one compact pill per configured site handle, or
                           a single "primary" pill when the link runs primary-only. #}
                        <td>
                            <div class="influx-pill-group">
                                {% set siteHandles = link.siteHandles() %}
                                {% if siteHandles is empty %}
                                    {{ ui.pill("primary"|t("influx"), "blue") }}
                                {% else %}
                                    {% for site in siteHandles %}
                                        {{ ui.pill(site, "gray") }}
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </td>

                        {# Processing — the configured actions as one wrapping row
                           of pills, in canonical order, coloured by the palette. #}
                        <td>
                            {% set present = processingOrder|filter(v => v in link.processing) %}
                            {% if present is empty %}
                                <span class="light">—</span>
                            {% else %}
                                <div class="influx-pill-group">
                                    {% for verb in present %}{{ ui.processingPill(verb) }}{% endfor %}
                                </div>
                            {% endif %}
                        </td>

                        {# Last run — status dot + human time linking to the log,
                           and a compact result-summary sub-line below. #}
                        <td>
                            {% if link.lastRunAt %}
                                {% set lastLog = link.lastLogId ? (lastLogs[link.lastLogId] ?? null) : null %}
                                {% set when = craft.app.formattingLocale.getFormatter().asDatetime(link.lastRunAt) %}
                                {% if lastLog %}
                                    <span class="status {{ logPresenter.statusColor(lastLog.status) }}" title="{{ lastLog.status|t('influx') }}"></span>
                                    <a href="{{ cpUrl('influx/logs/' ~ lastLog.id) }}">{{ when }}</a>
                                    {% if lastLog.status == "error" %}
                                        <div class="influx-cell-sub">
                                            {{- "failed"|t("influx") -}}
                                            {%- if lastLog.error %} — {{ lastLog.error|split("\n")|first }}{% endif -%}
                                        </div>
                                    {% else %}
                                        {% set parts = [] %}
                                        {% for segment in logPresenter.resultSegments(lastLog) %}
                                            {% set parts = parts|merge([segment.count ~ " " ~ ui.resultNoun(segment.kind)]) %}
                                        {% endfor %}
                                        {% set duration = logPresenter.durationLabel(lastLog) %}
                                        {% if duration %}{% set parts = parts|merge([duration]) %}{% endif %}
                                        {% if parts is not empty %}
                                            <div class="influx-cell-sub">{{ parts|join(" · ") }}</div>
                                        {% endif %}
                                    {% endif %}
                                {% else %}
                                    {# The run's log has been deleted — only the timestamp persists on the link. #}
                                    <span class="status" title="{{ 'Log removed'|t('influx') }}"></span>
                                    {{ when }}
                                {% endif %}
                            {% else %}
                                <span class="status"></span>
                                <span class="light">{{ "never ran"|t("influx") }}</span>
                            {% endif %}
                        </td>

                        {# Actions — one primary Sync (with the site/offset preset
                           menu) plus a three-dots overflow menu for everything
                           else. `.thin` collapses the column so it sits flush right. #}
                        <td class="thin">
                            {% set siteHandles = link.siteHandles() %}
                            {% set multiSite = siteHandles|length > 1 %}
                            {% set siteScopes = multiSite ? [null]|merge(siteHandles) : [null] %}
                            {% set presetHandles = link.offset|keys %}

                            {# One hidden form per (site scope × offset preset) the
                               buttons below submit. Hoisted out of the btngroup so
                               Craft's .btngroup radius rules (which target
                               .btn:first-child / :last-child) still match. #}
                            {% for site in siteScopes %}
                                {% for presetHandle in [null]|merge(presetHandles) %}
                                    <form id="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--{{ presetHandle ?? "default" }}"
                                          method="post" accept-charset="UTF-8" hidden>
                                        {{ csrfInput() }}
                                        {{ actionInput("influx/synchronization/link") }}
                                        {{ hiddenInput("handle", link.handle) }}
                                        {% if site is not null %}{{ hiddenInput("site", site) }}{% endif %}
                                        {% if presetHandle is not null %}{{ hiddenInput("offset", presetHandle) }}{% endif %}
                                    </form>
                                {% endfor %}
                            {% endfor %}

                            {% if not readOnly %}
                                <form id="influx-delete-{{ link.handle }}" method="post" accept-charset="UTF-8" hidden>
                                    {{ csrfInput() }}
                                    {{ actionInput("influx/links/delete") }}
                                    {{ redirectInput("influx/links") }}
                                    {{ hiddenInput("uid", link.uid) }}
                                </form>
                            {% endif %}

                            <div class="flex flex-nowrap influx-row-actions">
                                <div class="btngroup">
                                    <button type="submit"
                                            form="influx-sync-{{ link.handle }}--all--default"
                                            class="btn"
                                            data-icon="refresh"
                                            title="{{ 'Sync'|t('influx') }}">
                                        {{ "Sync"|t("influx") }}
                                    </button>

                                    {% if presetHandles is not empty or multiSite %}
                                        <button type="button" class="btn menubtn" title="{{ 'Sync options'|t('influx') }}"></button>
                                        <div class="menu influx-sync-menu" data-align="right">
                                            {% if multiSite %}
                                                {% for site in siteScopes %}
                                                    {% if not loop.first %}<hr>{% endif %}
                                                    <h6>{{ site is null ? "All sites"|t("influx") : "Site {site}"|t("influx", { site: site }) }}</h6>
                                                    <ul>
                                                        <li>
                                                            <button type="submit"
                                                                    form="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--default"
                                                                    class="menu-option">
                                                                {{ "all"|t("influx") }}
                                                            </button>
                                                        </li>
                                                        {% for presetHandle in presetHandles %}
                                                            <li>
                                                                <button type="submit"
                                                                        form="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--{{ presetHandle }}"
                                                                        class="menu-option">
                                                                    {{ presetHandle }}
                                                                </button>
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                {% endfor %}
                                            {% else %}
                                                <ul>
                                                    {% for presetHandle in presetHandles %}
                                                        <li>
                                                            <button type="submit"
                                                                    form="influx-sync-{{ link.handle }}--all--{{ presetHandle }}"
                                                                    class="menu-option">
                                                                {{ presetHandle }}
                                                            </button>
                                                        </li>
                                                    {% endfor %}
                                                </ul>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>

                                {# Overflow: Debug + Duplicate + Delete, folded into one
                                   three-dots menu the way Craft's element rows do
                                   (`action-btn` renders the ellipsis, no caret). #}
                                <button type="button" class="btn menubtn action-btn" title="{{ 'Actions'|t('influx') }}" aria-label="{{ 'Debug, duplicate or delete'|t('influx') }}"></button>
                                <div class="menu" data-align="right">
                                    <ul>
                                        <li>
                                            <a href="{{ cpUrl('influx/debug', { link: link.handle }) }}" data-icon="search">
                                                {{ "Debug"|t("influx") }}
                                            </a>
                                        </li>
                                        {% if not readOnly %}
                                            <li>
                                                <a href="{{ cpUrl('influx/links/' ~ link.id ~ '/duplicate') }}" data-icon="duplicate">
                                                    {{ "Duplicate"|t("influx") }}
                                                </a>
                                            </li>
                                        {% endif %}
                                    </ul>
                                    {% if not readOnly %}
                                        <hr>
                                        <ul>
                                            <li>
                                                <a class="error" data-icon="trash"
                                                   role="button"
                                                   data-influx-delete-form="influx-delete-{{ link.handle }}">
                                                    {{ "Delete link"|t("influx") }}
                                                </a>
                                            </li>
                                        </ul>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
