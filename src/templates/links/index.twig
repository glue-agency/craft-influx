{% extends "_layouts/cp" %}
{% set title = "Links"|t("influx") %}
{% set selectedSubnavItem = "links" %}

{% import "_includes/forms" as forms %}

{% block actionButton %}
    {% if not readOnly %}
        <a href="{{ cpUrl('influx/links/new') }}" class="btn submit add icon">
            {{ "New link"|t("influx") }}
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    {% if not readOnly %}
        {% js %}
        document.querySelectorAll('.influx-duplicate-form').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                const source = form.querySelector('input[name="handle"]').value;
                const suggested = source + 'Copy';
                const answer = window.prompt({{ "New handle for the duplicated link:"|t("influx")|json_encode|raw }}, suggested);
                if (!answer) {
                    e.preventDefault();
                    return;
                }
                form.querySelector('input[name="newHandle"]').value = answer.trim();
            });
        });
        {% endjs %}
    {% endif %}

    {% if links is empty %}
        <div class="zilch">
            <p>{{ "No links yet."|t("influx") }}</p>
            {% if readOnly %}
                <p class="light">{{ "Administrative changes are disallowed in this environment."|t("influx") }}</p>
            {% endif %}
        </div>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Name"|t("influx") }}</th>
                    <th>{{ "Handle"|t("influx") }}</th>
                    <th>{{ "Target"|t("influx") }}</th>
                    <th>{{ "Sites"|t("influx") }}</th>
                    <th>{{ "Last run"|t("influx") }}</th>
                    <th colspan="2">{{ "Actions"|t('influx') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for link in links %}
                    {% set lastRun = lastRuns[link.handle] ?? null %}
                    <tr>
                        <td>
                            <a href="{{ cpUrl('influx/links/' ~ link.id) }}">
                                <strong>{{ link.name }}</strong>
                            </a>
                        </td>
                        <td><code>{{ link.handle }}</code></td>
                        <td>
                            {{ link.elementTypeLabel() }}
                            {% if link.elementCriteria.section is defined %}
                                <span class="light">/ {{ link.elementCriteria.section }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set sites = link.siteHandles() %}
                            {% if sites is empty %}
                                <span class="light">{{ "primary"|t("influx") }}</span>
                            {% else %}
                                {{ sites|join(", ") }}
                            {% endif %}
                        </td>
                        <td>
                            {% if lastRun %}
                                <span class="status {{ lastRun.status == "ok" ? "live" : (lastRun.status == "error" ? "expired" : "pending") }}"
                                      title="{{ lastRun.status|t('influx') }}"></span>
                                <a href="{{ cpUrl('influx/logs/' ~ lastRun.id) }}">
                                    {{ craft.app.formattingLocale.getFormatter().asDatetime(lastRun.startedAt) }}
                                </a>
                            {% else %}
                                <span class="light">{{ "never"|t("influx") }}</span>
                            {% endif %}
                        </td>
                        <td class="thin">
                            {# A link with 2+ site-specific endpoints can be synced per site;
                               otherwise "all sites" is the only scope. Offset presets stay
                               available within whichever scope. #}
                            {% set siteHandles = link.siteHandles() %}
                            {% set multiSite = siteHandles|length > 1 %}
                            {% set siteScopes = multiSite ? [null]|merge(siteHandles) : [null] %}
                            {% set presetHandles = link.offset|keys %}

                            {# Forms hoisted out of the btngroup so the buttons can sit as direct
                               children — Craft's .btngroup radius rules target .btn:first-child /
                               :last-child, which would never match when the buttons are wrapped.
                               One form per (site scope × offset preset) the buttons below submit. #}
                            {% for site in siteScopes %}
                                {% for presetHandle in [null]|merge(presetHandles) %}
                                    <form id="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--{{ presetHandle ?? "default" }}"
                                          method="post" accept-charset="UTF-8" hidden>
                                        {{ csrfInput() }}
                                        {{ actionInput("influx/synchronization/link") }}
                                        {{ hiddenInput("handle", link.handle) }}
                                        {% if site is not null %}{{ hiddenInput("site", site) }}{% endif %}
                                        {% if presetHandle is not null %}{{ hiddenInput("offset", presetHandle) }}{% endif %}
                                    </form>
                                {% endfor %}
                            {% endfor %}

                            {% if not readOnly %}
                                <form id="influx-duplicate-{{ link.handle }}" method="post" accept-charset="UTF-8" class="influx-duplicate-form" hidden>
                                    {{ csrfInput() }}
                                    {{ actionInput("influx/links/duplicate") }}
                                    {{ hiddenInput("handle", link.handle) }}
                                    {{ hiddenInput("newHandle", "") }}
                                </form>
                            {% endif %}

                            <div class="btngroup">
                                <button type="submit"
                                        form="influx-sync-{{ link.handle }}--all--default"
                                        class="btn"
                                        data-icon="refresh"
                                        title="{{ 'Sync'|t('influx') }}">
                                    {{ "Sync"|t("influx") }}
                                </button>

                                {% if presetHandles is not empty or multiSite %}
                                    <button type="button" class="btn menubtn" title="{{ 'Sync options'|t('influx') }}"></button>
                                    <div class="menu" data-align="right">
                                        {% if multiSite %}
                                            {% for site in siteScopes %}
                                                {% if not loop.first %}<hr>{% endif %}
                                                <h6>{{ site is null ? "All sites"|t("influx") : "Site {site}"|t("influx", { site: site }) }}</h6>
                                                <ul>
                                                    <li>
                                                        <button type="submit"
                                                                form="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--default"
                                                                class="menu-option">
                                                            {{ "all"|t("influx") }}
                                                        </button>
                                                    </li>
                                                    {% for presetHandle in presetHandles %}
                                                        <li>
                                                            <button type="submit"
                                                                    form="influx-sync-{{ link.handle }}--{{ site ?? "all" }}--{{ presetHandle }}"
                                                                    class="menu-option">
                                                                {{ presetHandle }}
                                                            </button>
                                                        </li>
                                                    {% endfor %}
                                                </ul>
                                            {% endfor %}
                                        {% else %}
                                            <ul>
                                                {% for presetHandle in presetHandles %}
                                                    <li>
                                                        <button type="submit"
                                                                form="influx-sync-{{ link.handle }}--all--{{ presetHandle }}"
                                                                class="menu-option">
                                                            {{ presetHandle }}
                                                        </button>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="thin">
                            <div class="btngroup">
                                <a href="{{ cpUrl('influx/links/' ~ link.id ~ '/debug') }}"
                                   class="btn"
                                   data-icon="search"
                                   title="{{ 'Debug'|t('influx') }}">
                                    {{ "Debug"|t("influx") }}
                                </a>

                                {% if not readOnly %}
                                    <button type="submit"
                                            form="influx-duplicate-{{ link.handle }}"
                                            class="btn"
                                            data-icon="duplicate"
                                            title="{{ 'Duplicate'|t('influx') }}">
                                        {{ "Duplicate"|t("influx") }}
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
