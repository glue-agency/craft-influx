{% extends "_layouts/cp" %}
{% set title = "Debug"|t("influx") ~ ": " ~ link.name %}
{% set selectedSubnavItem = "links" %}

{% set crumbs = [
    { label: "Influx"|t("influx"), url: cpUrl("influx") },
    { label: "Links"|t("influx"), url: cpUrl("influx/links") },
    { label: link.name, url: cpUrl("influx/links/" ~ link.id) },
] %}

{# Empty action-buttons slot for the SPA to Teleport its Inspect button into,
   so the primary action sits in the page header like every other CP screen.
   Defining the block is what makes Craft render the #action-buttons container. #}
{% block actionButton %}
    <div id="influx-debug-actions" class="flex"></div>
{% endblock %}

{% block content %}
    {# Mount point for the Vue debug inspector (DebugApp). Bootstrap config
       rides along as a JSON data attribute. #}
    <div data-influx-debug="{{ {
        inspectUrl: inspectUrl,
        selectedSite: selectedSite,
        selectedOffset: selectedOffset,
        limit: limit,
        sites: sites,
        offsetHandles: offsetHandles,
        processing: processing,
    }|json_encode }}"></div>
{% endblock %}
