{% extends "_layouts/cp" %}
{% set title = "Run "|t("influx") ~ "#" ~ config.log.id %}
{% set selectedSubnavItem = "logs" %}

{% set crumbs = [
    { label: "Influx"|t("influx"), url: cpUrl("influx") },
    { label: "Logs"|t("influx"), url: cpUrl("influx/logs") },
] %}

{% block content %}
    {# Mount point for the Vue run-log viewer (LogApp). Bootstrap config
       (summary, counters, items, stream URLs) rides along as JSON. #}
    <div data-influx-log="{{ config|json_encode }}"></div>
{% endblock %}
