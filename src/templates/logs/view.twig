{% extends "_layouts/cp" %}
{% set title = "Run "|t("influx") ~ "#" ~ log.id %}
{% set selectedSubnavItem = "logs" %}

{% set crumbs = [
    { label: "Influx"|t("influx"), url: cpUrl("influx") },
    { label: "Logs"|t("influx"), url: cpUrl("influx/logs") },
] %}

{% set isLive = log.status in ['running', 'pending'] %}

{% block content %}
    <table class="data fullwidth fixed-layout">
        <tbody>
            <tr><th>{{ "Link"|t("influx") }}</th><td><a href="{{ cpUrl("influx/links/" ~ log.linkHandle) }}"><code>{{ log.linkHandle }}</code></a></td></tr>
            <tr><th>{{ "Trigger"|t("influx") }}</th><td>{{ log.trigger }}</td></tr>
            <tr>
                <th>{{ "Status"|t("influx") }}</th>
                <td id="influx-log-status-cell">
                    <span class="status {{ log.status == "ok" ? "live" : (log.status == "error" ? "expired" : "pending") }}"></span>
                    <span class="influx-log-status">{{ log.status }}</span>
                </td>
            </tr>
            <tr><th>{{ "Started"|t("influx") }}</th><td>{{ craft.app.formattingLocale.getFormatter().asDatetime(log.startedAt) }}</td></tr>
            <tr><th>{{ "Finished"|t("influx") }}</th><td id="influx-log-finished">{{ log.finishedAt ? craft.app.formattingLocale.getFormatter().asDatetime(log.finishedAt) : "—" }}</td></tr>
            <tr id="influx-log-error-row" {% if not log.error %}hidden{% endif %}>
                <th>{{ "Error"|t("influx") }}</th>
                <td><pre class="error" id="influx-log-error">{{ log.error }}</pre></td>
            </tr>
        </tbody>
    </table>

    <h2>{{ "Counters"|t("influx") }}</h2>
    <table class="data fullwidth fixed-layout">
        <tbody>
            <tr><th>{{ "Seen"|t("influx") }}</th><td data-counter="itemsSeen">{{ log.itemsSeen }}</td></tr>
            <tr><th>{{ "Created"|t("influx") }}</th><td data-counter="itemsCreated">{{ log.itemsCreated }}</td></tr>
            <tr><th>{{ "Updated"|t("influx") }}</th><td data-counter="itemsUpdated">{{ log.itemsUpdated }}</td></tr>
            <tr><th>{{ "Unchanged"|t("influx") }}</th><td data-counter="itemsUnchanged">{{ log.itemsUnchanged }}</td></tr>
            <tr><th>{{ "Skipped"|t("influx") }}</th><td data-counter="itemsSkipped">{{ log.itemsSkipped }}</td></tr>
            <tr><th>{{ "Deleted / disabled"|t("influx") }}</th><td data-counter="itemsDeleted">{{ log.itemsDeleted }}</td></tr>
        </tbody>
    </table>

    <h2>
        {{ "Items"|t("influx") }}
        {% if isLive %}<span class="light" id="influx-log-stream-status">— {{ "connecting…"|t("influx") }}</span>{% endif %}
    </h2>

    {% set filterColors = {
        "created":   "live",
        "updated":   "live",
        "unchanged": "pending",
        "skipped":   "pending",
        "deleted":   "expired",
        "disabled":  "expired",
    } %}
    <div class="flex influx-log-filters" id="influx-log-filters" style="gap:.4em; margin:0 0 14px; flex-wrap:wrap;">
        {% for action, color in filterColors %}
            <button type="button" class="btn active influx-log-filter" data-filter-action="{{ action }}">
                <span class="status {{ color }}"></span>
                <span>{{ action|t("influx") }}</span>
                <span class="light influx-log-filter-count" style="margin-left:.4em;">0</span>
            </button>
        {% endfor %}
    </div>

    <table class="data fullwidth" id="influx-log-items-table">
        <thead>
            <tr>
                <th>#</th>
                <th>{{ "Action"|t("influx") }}</th>
                <th>{{ "Match value"|t("influx") }}</th>
                <th>{{ "Element"|t("influx") }}</th>
                <th>{{ "Message"|t("influx") }}</th>
            </tr>
        </thead>
        <tbody id="influx-log-items-body">
            {% for item in items %}
                {% set color = {
                    "created":   "live",
                    "updated":   "live",
                    "unchanged": "pending",
                    "skipped":   "pending",
                    "disabled":  "expired",
                    "deleted":   "expired",
                    "deleted-for-site": "expired",
                    "error":     "expired",
                }[item.action] ?? "pending" %}
                <tr data-item-id="{{ item.id }}" data-action="{{ item.action }}" class="influx-log-row">
                    <td>
                        <button type="button" class="btn small influx-log-inspect" title="{{ 'Inspect'|t('influx') }}" data-icon="search">{{ item.id }}</button>
                    </td>
                    <td>
                        <span class="status {{ color }}"></span>
                        <code>{{ item.action }}</code>
                    </td>
                    <td><code>{{ item.matchValue ?: "—" }}</code></td>
                    <td>
                        {% if item.elementId %}
                            {% set el = craft.app.elements.getElementById(item.elementId) %}
                            {% if el %}
                                {{ influxElementChip(el, { hyperlink: true }) }}
                            {% else %}
                                <span class="light">#{{ item.elementId }} ({{ "gone"|t("influx") }})</span>
                            {% endif %}
                        {% else %}
                            <span class="light">—</span>
                        {% endif %}
                    </td>
                    <td>{{ item.message ?: "" }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if items is empty and not isLive %}
        <p class="light">{{ "No per-item rows."|t("influx") }}</p>
    {% endif %}

    {% js %}
    (function () {
        const filtersEl = document.getElementById('influx-log-filters');
        const tbody = document.getElementById('influx-log-items-body');
        if (!filtersEl || !tbody) return;

        const ACTIONS = ['created','updated','unchanged','skipped','deleted','disabled'];

        function activeSet() {
            const set = new Set();
            filtersEl.querySelectorAll('.influx-log-filter.active').forEach(function (btn) {
                set.add(btn.getAttribute('data-filter-action'));
            });
            return set;
        }

        function applyVisibility() {
            const active = activeSet();
            tbody.querySelectorAll('tr[data-action]').forEach(function (tr) {
                const a = tr.getAttribute('data-action');
                tr.hidden = ACTIONS.includes(a) && !active.has(a);
            });
            // Keep expanded detail rows in lockstep with their parent row.
            tbody.querySelectorAll('tr.influx-log-detail').forEach(function (tr) {
                const prev = tr.previousElementSibling;
                tr.hidden = !!(prev && prev.hidden);
            });
        }

        function recount() {
            const counts = {};
            ACTIONS.forEach(function (a) { counts[a] = 0; });
            tbody.querySelectorAll('tr[data-action]').forEach(function (tr) {
                const a = tr.getAttribute('data-action');
                if (counts[a] != null) counts[a]++;
            });
            filtersEl.querySelectorAll('.influx-log-filter').forEach(function (btn) {
                const a = btn.getAttribute('data-filter-action');
                const span = btn.querySelector('.influx-log-filter-count');
                if (span) span.textContent = counts[a] || 0;
            });
        }

        filtersEl.addEventListener('click', function (e) {
            const btn = e.target.closest('.influx-log-filter');
            if (!btn) return;
            btn.classList.toggle('active');
            applyVisibility();
        });

        recount();
        window.__influxLogFilters = { applyVisibility: applyVisibility, recount: recount };
    })();

    (function () {
        const tbody = document.getElementById('influx-log-items-body');
        if (!tbody) return;

        const urlTemplate = {{ itemUrlTemplate|json_encode|raw }};
        const COLS = 5;

        function detailRowFor(tr) {
            const next = tr.nextElementSibling;
            return (next && next.classList.contains('influx-log-detail')) ? next : null;
        }

        function buildDetailRow(html) {
            const tr = document.createElement('tr');
            tr.className = 'influx-log-detail';
            const td = document.createElement('td');
            td.colSpan = COLS;
            td.style.background = '#f3f7fc';
            td.innerHTML = html;
            tr.appendChild(td);
            return tr;
        }

        tbody.addEventListener('click', function (e) {
            const btn = e.target.closest('.influx-log-inspect');
            if (!btn) return;
            const tr = btn.closest('tr[data-item-id]');
            if (!tr) return;
            e.preventDefault();

            const existing = detailRowFor(tr);
            if (existing) {
                existing.remove();
                return;
            }

            const detail = buildDetailRow('<p class="light" style="padding:8px;"><span class="spinner"></span> ' + Craft.t('influx', 'Loading…') + '</p>');
            tr.insertAdjacentElement('afterend', detail);

            const id = tr.getAttribute('data-item-id');
            const url = urlTemplate.replace('__ID__', encodeURIComponent(id));

            Craft.sendActionRequest('GET', url).then(function (response) {
                detail.querySelector('td').innerHTML = response.data && response.data.html
                    ? response.data.html
                    : '<p class="error" style="padding:8px;">' + Craft.t('influx', 'No content returned.') + '</p>';
            }).catch(function (err) {
                const msg = (err && err.response && err.response.data && err.response.data.message)
                    || err.message
                    || 'Request failed.';
                const td = detail.querySelector('td');
                td.innerHTML = '';
                const p = document.createElement('p');
                p.className = 'error';
                p.style.padding = '8px';
                p.textContent = msg;
                td.appendChild(p);
            });
        });
    })();
    {% endjs %}

    {% if isLive %}
        {% set lastItemId = items|length ? items|last.id : 0 %}
        {% js %}
        (function () {
            const streamBase = {{ streamUrl|json_encode|raw }};
            const url = streamBase + (streamBase.includes('?') ? '&' : '?') + 'lastId={{ lastItemId }}';

            const body = document.getElementById('influx-log-items-body');
            const statusLabel = document.getElementById('influx-log-stream-status');
            const statusCell = document.getElementById('influx-log-status-cell');
            const finishedCell = document.getElementById('influx-log-finished');
            const errorRow = document.getElementById('influx-log-error-row');
            const errorPre = document.getElementById('influx-log-error');

            const actionColors = {
                'created':   'live',
                'updated':   'live',
                'unchanged': 'pending',
                'skipped':   'pending',
                'disabled':  'expired',
                'deleted':   'expired',
                'deleted-for-site': 'expired',
                'error':     'expired',
            };

            function escapeHtml(s) {
                return String(s == null ? '' : s)
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function appendItem(d) {
                if (document.querySelector('tr[data-item-id="' + d.id + '"]')) return;
                const tr = document.createElement('tr');
                tr.setAttribute('data-item-id', d.id);
                tr.setAttribute('data-action', d.action);
                const color = actionColors[d.action] || 'pending';
                tr.classList.add('influx-log-row');
                tr.innerHTML =
                    '<td><button type="button" class="btn small influx-log-inspect" data-icon="search">' + escapeHtml(d.id) + '</button></td>' +
                    '<td><span class="status ' + color + '"></span> <code>' + escapeHtml(d.action) + '</code></td>' +
                    '<td><code>' + (d.matchValue ? escapeHtml(d.matchValue) : '—') + '</code></td>' +
                    '<td>' + (d.elementHtml || '<span class="light">—</span>') + '</td>' +
                    '<td>' + escapeHtml(d.message) + '</td>';
                body.appendChild(tr);
                if (window.__influxLogFilters) {
                    window.__influxLogFilters.recount();
                    window.__influxLogFilters.applyVisibility();
                }
            }

            function updateCounters(d) {
                ['itemsSeen','itemsCreated','itemsUpdated','itemsUnchanged','itemsSkipped','itemsDeleted'].forEach(function (k) {
                    const cell = document.querySelector('[data-counter="' + k + '"]');
                    if (cell) cell.textContent = d[k];
                });
                if (d.status) {
                    const cls = d.status === 'ok' ? 'live' : (d.status === 'error' ? 'expired' : 'pending');
                    statusCell.querySelector('.status').className = 'status ' + cls;
                    statusCell.querySelector('.influx-log-status').textContent = d.status;
                }
                if (d.finishedAt) finishedCell.textContent = d.finishedAt;
                if (d.error) {
                    errorPre.textContent = d.error;
                    errorRow.hidden = false;
                }
            }

            const es = new EventSource(url, { withCredentials: true });
            statusLabel.textContent = '— ' + {{ "streaming…"|t("influx")|json_encode|raw }};

            es.addEventListener('item', function (e) {
                try { appendItem(JSON.parse(e.data)); } catch (err) { console.error(err); }
            });

            es.addEventListener('counters', function (e) {
                try { updateCounters(JSON.parse(e.data)); } catch (err) { console.error(err); }
            });

            es.addEventListener('done', function () {
                statusLabel.textContent = '';
                es.close();
            });

            es.addEventListener('error', function () {
                statusLabel.innerHTML = '<span class="error">' + {{ "stream closed"|t("influx")|json_encode|raw }} + '</span>';
                es.close();
            });
        })();
        {% endjs %}
    {% endif %}
{% endblock %}
