{% extends "_layouts/cp" %}
{% set title = "Logs"|t("influx") %}
{% set selectedSubnavItem = "logs" %}

{% block actionButton %}
    <form method="post" accept-charset="UTF-8" onsubmit="return confirm('{{ "Delete every log entry?"|t("influx") }}');">
        {{ csrfInput() }}
        {{ actionInput("influx/logs/clear") }}
        <button type="submit" class="btn" data-icon="trash">{{ "Clear all"|t("influx") }}</button>
    </form>
{% endblock %}

{% block content %}
    {% set statusDots = { ok: 'live', error: 'expired' } %}

    {% if logs is empty and not status %}
        <div class="zilch">
            <p>{{ "No runs yet."|t("influx") }}</p>
        </div>
    {% else %}
        {# Server-rendered status filter: a native Craft menu (auto-wired by the
           CP) whose options are links to ?status=…, dropping the page so the
           filter always starts on page one. #}
        <div class="influx-logs-toolbar" style="margin-bottom: 14px;">
            <button type="button" class="btn menubtn">
                <span class="status {{ status ? (statusDots[status] ?? 'pending') }}"></span>{{ (status ?? 'All')|t('influx') }}
            </button>
            <div class="menu">
                <ul class="padded">
                    <li>
                        <a href="{{ cpUrl('influx/logs') }}"{% if not status %} class="sel"{% endif %}>
                            <span class="status"></span>{{ "All"|t("influx") }}
                        </a>
                    </li>
                    {% for s in statuses %}
                        <li>
                            <a href="{{ cpUrl('influx/logs', { status: s }) }}"{% if status == s %} class="sel"{% endif %}>
                                <span class="status {{ statusDots[s] ?? 'pending' }}"></span>{{ s|t('influx') }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        {% if logs is empty %}
            <div class="zilch">
                <p>{{ "No runs match this status."|t("influx") }}</p>
            </div>
        {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Started"|t("influx") }}</th>
                    <th>{{ "Link"|t("influx") }}</th>
                    <th>{{ "Trigger"|t("influx") }}</th>
                    <th>{{ "Status"|t("influx") }}</th>
                    <th>{{ "Seen"|t("influx") }}</th>
                    <th>{{ "Created"|t("influx") }}</th>
                    <th>{{ "Updated"|t("influx") }}</th>
                    <th>{{ "Unchanged"|t("influx") }}</th>
                    <th>{{ "Skipped"|t("influx") }}</th>
                    <th>{{ "Duration"|t("influx") }}</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>
                            <a href="{{ cpUrl("influx/logs/" ~ log.id) }}">
                                {{ craft.app.formattingLocale.getFormatter().asDatetime(log.startedAt, 'short') }}
                            </a>
                        </td>
                        <td>
                            {% set linkId = linkIds[log.linkHandle] ?? null %}
                            {% set linkName = linkNames[log.linkHandle] ?? log.linkHandle %}
                            {% if linkId %}
                                <a href="{{ cpUrl("influx/links/" ~ linkId) }}">{{ linkName }}</a>
                            {% else %}
                                {{ linkName }}
                            {% endif %}
                        </td>
                        <td>{{ log.trigger }}</td>
                        <td>
                            <span class="status {{ statusDots[log.status] ?? 'pending' }}"></span>
                            {{ log.status }}
                        </td>
                        <td>{{ log.itemsSeen }}</td>
                        <td>{{ log.itemsCreated }}</td>
                        <td>{{ log.itemsUpdated }}</td>
                        <td>{{ log.itemsUnchanged }}</td>
                        <td>{{ log.itemsSkipped }}</td>
                        <td>
                            {% if log.finishedAt %}
                                {{ ((log.finishedAt|date_modify('+0 seconds')).timestamp - (log.startedAt|date_modify('+0 seconds')).timestamp) }}s
                            {% else %}
                                <span class="light">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% set totalPages = (total / perPage)|round(0, "ceil") %}
        {% if totalPages > 1 %}
            {% set pagerParams = status ? { status: status } : {} %}
            <nav class="pagination" style="margin-top: 14px;">
                {% if page > 1 %}
                    <a class="btn" href="{{ cpUrl('influx/logs', pagerParams|merge({ page: page - 1 })) }}">← {{ "Previous"|t("influx") }}</a>
                {% endif %}
                <span class="light">{{ "Page"|t("influx") }} {{ page }} / {{ totalPages }}</span>
                {% if page < totalPages %}
                    <a class="btn" href="{{ cpUrl('influx/logs', pagerParams|merge({ page: page + 1 })) }}">{{ "Next"|t("influx") }} →</a>
                {% endif %}
            </nav>
        {% endif %}
        {% endif %}
    {% endif %}
{% endblock %}
