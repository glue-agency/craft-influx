{% extends "_layouts/cp" %}
{% set title = "Logs"|t("influx") %}
{% set selectedSubnavItem = "logs" %}

{% block actionButton %}
    <form method="post" accept-charset="UTF-8" onsubmit="return confirm('{{ "Delete every log entry?"|t("influx") }}');">
        {{ csrfInput() }}
        {{ actionInput("influx/logs/clear") }}
        <button type="submit" class="btn" data-icon="trash">{{ "Clear all"|t("influx") }}</button>
    </form>
{% endblock %}

{% block content %}
    {% set statusDots = { ok: 'live', error: 'expired' } %}

    {% js %}
    document.querySelectorAll('[data-influx-delete-form]').forEach(function (anchor) {
        anchor.addEventListener('click', function () {
            if (window.confirm({{ "Delete this log entry?"|t("influx")|json_encode|raw }})) {
                document.getElementById(anchor.dataset.influxDeleteForm).submit();
            }
        });
    });
    {% endjs %}

    {% if logs is empty %}
        <div class="zilch">
            <p>{{ "No runs yet."|t("influx") }}</p>
        </div>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Started"|t("influx") }}</th>
                    <th>{{ "Link"|t("influx") }}</th>
                    <th>{{ "Trigger"|t("influx") }}</th>
                    <th>{{ "Status"|t("influx") }}</th>
                    <th>{{ "Seen"|t("influx") }}</th>
                    <th>{{ "Created"|t("influx") }}</th>
                    <th>{{ "Updated"|t("influx") }}</th>
                    <th>{{ "Unchanged"|t("influx") }}</th>
                    <th>{{ "Skipped"|t("influx") }}</th>
                    <th>{{ "Duration"|t("influx") }}</th>
                    <th class="thin"></th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>
                            <a href="{{ cpUrl("influx/logs/" ~ log.id) }}">
                                {{ craft.app.formattingLocale.getFormatter().asDatetime(log.startedAt, 'short') }}
                            </a>
                        </td>
                        <td>
                            {% set linkId = linkIds[log.linkHandle] ?? null %}
                            {% set linkName = linkNames[log.linkHandle] ?? log.linkHandle %}
                            {% if linkId %}
                                <a href="{{ cpUrl("influx/links/" ~ linkId) }}">{{ linkName }}</a>
                            {% else %}
                                {{ linkName }}
                            {% endif %}
                        </td>
                        <td>{{ log.trigger }}</td>
                        <td>
                            <span class="status {{ statusDots[log.status] ?? 'pending' }}"></span>
                            {{ log.status }}
                        </td>
                        <td>{{ log.itemsSeen }}</td>
                        <td>{{ log.itemsCreated }}</td>
                        <td>{{ log.itemsUpdated }}</td>
                        <td>{{ log.itemsUnchanged }}</td>
                        <td>{{ log.itemsSkipped }}</td>
                        <td>
                            {% if log.finishedAt %}
                                {{ ((log.finishedAt|date_modify('+0 seconds')).timestamp - (log.startedAt|date_modify('+0 seconds')).timestamp) }}s
                            {% else %}
                                <span class="light">—</span>
                            {% endif %}
                        </td>
                        {# Craft's native table-row delete: the bare ✕ icon in its own
                           trailing thin cell, same as the links overview. Click →
                           confirm → submits the row's hidden delete form. #}
                        <td class="thin action">
                            <form id="influx-delete-log-{{ log.id }}" method="post" accept-charset="UTF-8" hidden>
                                {{ csrfInput() }}
                                {{ actionInput("influx/logs/delete") }}
                                {{ redirectInput("influx/logs") }}
                                {{ hiddenInput("id", log.id) }}
                            </form>
                            <a class="delete icon"
                               title="{{ 'Delete'|t('influx') }}"
                               aria-label="{{ 'Delete'|t('influx') }}"
                               role="button"
                               data-influx-delete-form="influx-delete-log-{{ log.id }}"></a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% set totalPages = (total / perPage)|round(0, "ceil") %}
        {% if totalPages > 1 %}
            <nav class="pagination" style="margin-top: 14px;">
                {% if page > 1 %}
                    <a class="btn" href="{{ cpUrl('influx/logs', { page: page - 1 }) }}">← {{ "Previous"|t("influx") }}</a>
                {% endif %}
                <span class="light">{{ "Page"|t("influx") }} {{ page }} / {{ totalPages }}</span>
                {% if page < totalPages %}
                    <a class="btn" href="{{ cpUrl('influx/logs', { page: page + 1 }) }}">{{ "Next"|t("influx") }} →</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
