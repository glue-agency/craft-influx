{% extends "_layouts/cp" %}

{% import "influx/_overview" as ui %}

{% set title = "Logs"|t("influx") %}
{% set selectedSubnavItem = "logs" %}

{# Status filter labels, in the display order the controller hands us. #}
{% set statusLabels = { running: "Running"|t("influx"), ok: "OK"|t("influx"), error: "Failed"|t("influx") } %}

{# Active filters, carried through the pager links so paging keeps the view. #}
{% set filterParams = { link: selectedLink, status: selectedStatus, trigger: selectedTrigger }|filter(v => v is not null and v != "") %}

{% block actionButton %}
    <form method="post" accept-charset="UTF-8" onsubmit="return confirm('{{ "Delete every log entry?"|t("influx") }}');">
        {{ csrfInput() }}
        {{ actionInput("influx/logs/clear") }}
        <button type="submit" class="btn" data-icon="trash">{{ "Clear all"|t("influx") }}</button>
    </form>
{% endblock %}

{% block content %}
    {% js %}
    document.querySelectorAll('[data-influx-delete-form]').forEach(function (anchor) {
        anchor.addEventListener('click', function () {
            if (window.confirm({{ "Delete this log entry?"|t("influx")|json_encode|raw }})) {
                document.getElementById(anchor.dataset.influxDeleteForm).submit();
            }
        });
    });

    // Filter selects submit their GET form on change; dropping the page param
    // (it isn't in the form) resets to page 1 for the new filter.
    document.querySelectorAll('[data-influx-filter]').forEach(function (select) {
        select.addEventListener('change', function () {
            this.form.submit();
        });
    });
    {% endjs %}

    {% css %}
    /* Give the toolbar selects a consistent minimum so they don't collapse to
       odd widths — mirrors the debug inspector's toolbar. */
    .influx-logs-toolbar .select { min-width: 160px; }
    .influx-logs-toolbar .select select { width: 100%; }
    {% endcss %}

    {# Filter by link, trigger and/or status without leaving the page. #}
    <form method="get" action="{{ cpUrl('influx/logs') }}" class="toolbar flex flex-nowrap influx-logs-toolbar" style="margin-bottom: 14px;">
        <div class="select">
            <select name="link" data-influx-filter aria-label="{{ 'Filter by link'|t('influx') }}">
                <option value="">{{ "All links"|t("influx") }}</option>
                {% for handle, name in linkNames %}
                    <option value="{{ handle }}"{{ handle == selectedLink ? " selected" }}>{{ name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="select">
            <select name="trigger" data-influx-filter aria-label="{{ 'Filter by trigger'|t('influx') }}">
                <option value="">{{ "All triggers"|t("influx") }}</option>
                {% for value, label in triggers %}
                    <option value="{{ value }}"{{ value == selectedTrigger ? " selected" }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="select">
            <select name="status" data-influx-filter aria-label="{{ 'Filter by status'|t('influx') }}">
                <option value="">{{ "All statuses"|t("influx") }}</option>
                {% for status in statuses %}
                    <option value="{{ status }}"{{ status == selectedStatus ? " selected" }}>{{ statusLabels[status] ?? status }}</option>
                {% endfor %}
            </select>
        </div>
    </form>

    {% if logs is empty %}
        <div class="zilch">
            <p>{{ "No runs yet."|t("influx") }}</p>
            {% if selectedLink or selectedStatus or selectedTrigger %}
                <p class="light"><a href="{{ cpUrl('influx/logs') }}">{{ "Clear filters"|t("influx") }}</a></p>
            {% endif %}
        </div>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Run"|t("influx") }}</th>
                    <th>{{ "Link"|t("influx") }}</th>
                    <th>{{ "Trigger"|t("influx") }}</th>
                    <th>{{ "Site"|t("influx") }}</th>
                    <th>{{ "Result"|t("influx") }}</th>
                    <th class="thin"></th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        {# Run — status dot + when linking to the detail, duration
                           and seen count on the sub-line. #}
                        <td>
                            <span class="status {{ presenter.statusColor(log.status) }}" title="{{ log.status|t('influx') }}"></span>
                            <a href="{{ cpUrl('influx/logs/' ~ log.id) }}">
                                {{ craft.app.formattingLocale.getFormatter().asDatetime(log.startedAt, "short") }}
                            </a>
                            {% if log.status in ["running", "pending"] %}
                                <div class="influx-cell-sub">{{ "running"|t("influx") }}</div>
                            {% else %}
                                {% set parts = [] %}
                                {% set duration = presenter.durationLabel(log) %}
                                {% if duration %}{% set parts = parts|merge([duration]) %}{% endif %}
                                {% if log.itemsSeen %}{% set parts = parts|merge([log.itemsSeen ~ " " ~ ui.resultNoun("seen")]) %}{% endif %}
                                {% if parts is not empty %}
                                    <div class="influx-cell-sub">{{ parts|join(" · ") }}</div>
                                {% endif %}
                            {% endif %}
                        </td>

                        {# Link — name links to its edit screen; a deleted link
                           degrades to its stored handle. #}
                        <td>
                            {% set linkId = linkIds[log.linkHandle] ?? null %}
                            {% set linkName = linkNames[log.linkHandle] ?? log.linkHandle %}
                            {% if linkId %}
                                <a href="{{ cpUrl('influx/links/' ~ linkId) }}">{{ linkName }}</a>
                            {% else %}
                                {{ linkName }}
                            {% endif %}
                        </td>

                        {# Trigger #}
                        <td>{{ ui.pill(log.trigger, "gray") }}</td>

                        {# Site the run was scoped to — a single-site run shows
                           its handle; a run with no site scope shows "primary",
                           the same as the Links overview. #}
                        <td>
                            {% if log.siteHandle %}
                                {{ ui.pill(log.siteHandle, "gray") }}
                            {% else %}
                                {{ ui.pill("primary"|t("influx"), "blue") }}
                            {% endif %}
                        </td>

                        {# Result — the six numeric columns as the shared pill
                           vocabulary. #}
                        <td>
                            {% set segments = presenter.resultSegments(log) %}
                            {% if segments is empty %}
                                <span class="light">{{ "no changes"|t("influx") }}</span>
                            {% else %}
                                <div class="influx-pill-group">
                                    {% for segment in segments %}{{ ui.resultPill(segment) }}{% endfor %}
                                </div>
                            {% endif %}
                        </td>

                        {# Delete — Craft's native row-delete icon; click → confirm
                           → submits the row's hidden form. #}
                        <td class="thin action">
                            <form id="influx-delete-log-{{ log.id }}" method="post" accept-charset="UTF-8" hidden>
                                {{ csrfInput() }}
                                {{ actionInput("influx/logs/delete") }}
                                {{ redirectInput("influx/logs") }}
                                {{ hiddenInput("id", log.id) }}
                            </form>
                            <a class="delete icon"
                               title="{{ 'Delete'|t('influx') }}"
                               aria-label="{{ 'Delete'|t('influx') }}"
                               role="button"
                               data-influx-delete-form="influx-delete-log-{{ log.id }}"></a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% set totalPages = (total / perPage)|round(0, "ceil") %}
        <div class="influx-table-foot">
            <span class="light">
                {{ total }} {{ (total == 1 ? "run" : "runs")|t("influx") }}
                {%- if retentionDays > 0 %} &middot; {{ "kept {n} days"|t("influx", { n: retentionDays }) }}{% endif -%}
            </span>
            {% if totalPages > 1 %}
                <nav class="pagination flex flex-nowrap">
                    {% if page > 1 %}
                        <a class="btn" href="{{ cpUrl('influx/logs', filterParams|merge({ page: page - 1 })) }}">&larr; {{ "Previous"|t("influx") }}</a>
                    {% endif %}
                    <span class="light">{{ "Page {page} of {total}"|t("influx", { page: page, total: totalPages }) }}</span>
                    {% if page < totalPages %}
                        <a class="btn" href="{{ cpUrl('influx/logs', filterParams|merge({ page: page + 1 })) }}">{{ "Next"|t("influx") }} &rarr;</a>
                    {% endif %}
                </nav>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
