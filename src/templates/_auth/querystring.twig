{# Form fields for the Query-string auth strategy. Included by
   `links/_edit.twig` inside a `{% namespace 'auth' %}` block. #}
{% import "_includes/forms.twig" as forms %}

{{ forms.textField({
    label: 'Parameter name'|t('influx'),
    instructions: 'e.g. <code>api_key</code>.'|t('influx')|raw,
    id: 'querystring-param',
    name: 'param',
    class: 'code',
    value: isActive ? (link.auth.param ?? '') : '',
    disabled: readOnly,
}) }}

{{ forms.textField({
    label: 'Token'|t('influx'),
    instructions: 'Appended to every request as the parameter value.'|t('influx'),
    id: 'querystring-token',
    name: 'token',
    class: 'code',
    value: isActive ? (link.auth.token ?? '') : '',
    disabled: readOnly,
}) }}
