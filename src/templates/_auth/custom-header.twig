{# Form fields for the Custom-header auth strategy. Included by
   `links/_edit.twig` inside a `{% namespace 'auth' %}` block. #}
{% import "_includes/forms.twig" as forms %}

{{ forms.textField({
    label: 'Header name'|t('influx'),
    instructions: 'e.g. <code>X-API-Key</code>.'|t('influx')|raw,
    id: 'custom-header',
    name: 'header',
    class: 'code',
    value: isActive ? (link.auth.header ?? '') : '',
    disabled: readOnly,
}) }}

{{ forms.textField({
    label: 'Token'|t('influx'),
    instructions: 'Used verbatim as the header value.'|t('influx'),
    id: 'custom-token',
    name: 'token',
    class: 'code',
    value: isActive ? (link.auth.token ?? '') : '',
    disabled: readOnly,
}) }}
