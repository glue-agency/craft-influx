# Copy to tests/.env and edit. Codeception reads this via the `params` directive
# in codeception.yml. Used by craftcms/test-framework to spin up a real Craft
# instance backed by a real (but throwaway) database.
#
# Use a DB you don't mind being wiped between runs.

# Craft
SECURITY_KEY=test-security-key-32chars-or-more!!
APP_ID=CraftCMS--influx-tests
ENVIRONMENT=test
PRIMARY_SITE_URL=https://test.craftcms.test/

# DB
DB_DRIVER=mysql
DB_SERVER=127.0.0.1
DB_PORT=3306
DB_DATABASE=influx_tests
DB_USER=root
DB_PASSWORD=
DB_SCHEMA=public
DB_TABLE_PREFIX=
